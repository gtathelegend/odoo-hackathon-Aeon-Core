# -----------------------------------------------------------------------------
# AssetFlow API — Environment configuration
# Copy this file to .env and fill in real values. Never commit .env to git.
# -----------------------------------------------------------------------------

# Runtime
NODE_ENV=development
PORT=5000
API_PREFIX=/api

# Database (Neon serverless Postgres via Prisma)
DATABASE_URL=
DIRECT_URL=

# Security / Auth
JWT_SECRET=change-me-in-production
JWT_REFRESH_SECRET=change-me-in-production
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=7d
COOKIE_SECRET=change-me-in-production

# CORS
CORS_ORIGIN=*
CORS_CREDENTIALS=true

# Rate limiting
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=100

# Request size limits
BODY_LIMIT=10mb

# Logging
LOG_LEVEL=info

# External services
GROK_API_KEY=        # Groq API key (get from https://console.groq.com)
RESEND_API_KEY=
CLOUDINARY_URL=

# File uploads
UPLOAD_DIR=uploads
UPLOAD_TEMP_DIR=uploads/temp
UPLOAD_MAX_SIZE=10485760
