// ================================ AI ========================================

model AssistantConversation {
  id     String  @id @default(uuid()) @db.Uuid
  userId String  @db.Uuid
  title  String?
  status String  @default("ACTIVE")
  model  String?

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?
  createdBy String?   @db.Uuid
  updatedBy String?   @db.Uuid
  version   Int       @default(1)
  isActive  Boolean   @default(true)

  user     User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages AssistantMessage[]
  feedback AssistantFeedback[]

  @@index([userId])
  @@map("assistant_conversations")
}

model AssistantMessage {
  id             String   @id @default(uuid()) @db.Uuid
  conversationId String   @db.Uuid
  role           String
  content        String
  tokens         Int?
  createdAt      DateTime @default(now())

  conversation AssistantConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  feedback     AssistantFeedback[]

  @@index([conversationId])
  @@index([createdAt])
  @@map("assistant_messages")
}

model AssistantPrompt {
  id          String  @id @default(uuid()) @db.Uuid
  key         String  @unique
  name        String
  template    String
  description String?

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?
  createdBy String?   @db.Uuid
  updatedBy String?   @db.Uuid
  version   Int       @default(1)
  isActive  Boolean   @default(true)

  @@index([key])
  @@map("assistant_prompts")
}

model AssistantFeedback {
  id             String   @id @default(uuid()) @db.Uuid
  conversationId String?  @db.Uuid
  messageId      String?  @db.Uuid
  userId         String?  @db.Uuid
  rating         Int?
  comment        String?
  createdAt      DateTime @default(now())

  conversation AssistantConversation? @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  message      AssistantMessage?      @relation(fields: [messageId], references: [id], onDelete: Cascade)

  @@index([conversationId])
  @@index([messageId])
  @@map("assistant_feedback")
}

