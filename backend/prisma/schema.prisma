// =============================== AUDIT ======================================

model AuditCycle {
  id           String      @id @default(uuid()) @db.Uuid
  name         String
  code         String      @unique
  status       AuditStatus @default(PLANNED)
  scope        String?
  departmentId String?     @db.Uuid
  startDate    DateTime?
  endDate      DateTime?
  closedAt     DateTime?

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?
  createdBy String?   @db.Uuid
  updatedBy String?   @db.Uuid
  version   Int       @default(1)
  isActive  Boolean   @default(true)

  assignments AuditAssignment[]
  records     AuditRecord[]
  history     AuditHistory[]

  @@index([code])
  @@index([status])
  @@index([departmentId])
  @@map("audit_cycles")
}

model AuditAssignment {
  id           String   @id @default(uuid()) @db.Uuid
  auditCycleId String   @db.Uuid
  auditorId    String?  @db.Uuid
  scopeNote    String?
  assignedAt   DateTime @default(now())

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?
  createdBy String?   @db.Uuid
  updatedBy String?   @db.Uuid
  version   Int       @default(1)
  isActive  Boolean   @default(true)

  cycle AuditCycle @relation(fields: [auditCycleId], references: [id], onDelete: Cascade)

  @@index([auditCycleId])
  @@index([auditorId])
  @@map("audit_assignments")
}

model AuditRecord {
  id              String     @id @default(uuid()) @db.Uuid
  auditCycleId    String     @db.Uuid
  assetId         String     @db.Uuid
  status          String     @default("PENDING")
  foundCondition  Condition?
  foundLocationId String?    @db.Uuid
  isVerified      Boolean    @default(false)
  verifiedBy      String?    @db.Uuid
  verifiedAt      DateTime?
  note            String?

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?
  createdBy String?   @db.Uuid
  updatedBy String?   @db.Uuid
  version   Int       @default(1)
  isActive  Boolean   @default(true)

  auditCycle AuditCycle @relation(fields: [auditCycleId], references: [id], onDelete: Cascade)
  asset      Asset      @relation(fields: [assetId], references: [id], onDelete: Cascade)

  discrepancies AuditDiscrepancy[]

  @@unique([auditCycleId, assetId])
  @@index([auditCycleId])
  @@index([assetId])
  @@index([isVerified])
  @@map("audit_records")
}

model AuditDiscrepancy {
  id            String    @id @default(uuid()) @db.Uuid
  auditRecordId String    @db.Uuid
  type          String
  description   String?
  severity      Priority  @default(MEDIUM)
  resolved      Boolean   @default(false)
  resolvedAt    DateTime?

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?
  createdBy String?   @db.Uuid
  updatedBy String?   @db.Uuid
  version   Int       @default(1)
  isActive  Boolean   @default(true)

  record AuditRecord @relation(fields: [auditRecordId], references: [id], onDelete: Cascade)

  @@index([auditRecordId])
  @@index([severity])
  @@map("audit_discrepancies")
}

model AuditHistory {
  id           String       @id @default(uuid()) @db.Uuid
  auditCycleId String       @db.Uuid
  action       String
  status       AuditStatus?
  note         String?
  performedBy  String?      @db.Uuid
  createdAt    DateTime     @default(now())

  cycle AuditCycle @relation(fields: [auditCycleId], references: [id], onDelete: Cascade)

  @@index([auditCycleId])
  @@index([createdAt])
  @@map("audit_histories")
}

