<odoo>
    <record id="group_employee" model="res.groups">
        <field name="name">AssetFlow Employee</field>
        <field name="category_id" ref="base.module_category_hidden"/>
        <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
    </record>

    <record id="group_department_head" model="res.groups">
        <field name="name">AssetFlow Department Head</field>
        <field name="category_id" ref="base.module_category_hidden"/>
        <field name="implied_ids" eval="[(4, ref('assetflow_erp.group_employee'))]"/>
    </record>

    <record id="group_asset_manager" model="res.groups">
        <field name="name">AssetFlow Asset Manager</field>
        <field name="category_id" ref="base.module_category_hidden"/>
        <field name="implied_ids" eval="[(4, ref('assetflow_erp.group_department_head'))]"/>
    </record>

    <record id="group_admin" model="res.groups">
        <field name="name">AssetFlow Admin</field>
        <field name="category_id" ref="base.module_category_hidden"/>
        <field name="implied_ids" eval="[(4, ref('assetflow_erp.group_asset_manager'))]"/>
    </record>

    <record id="asset_rule_employee_scope" model="ir.rule">
        <field name="name">Asset Employee Scope</field>
        <field name="model_id" ref="model_asset_asset"/>
        <field name="domain_force">['|',('current_holder_id.user_id','=',user.id),('create_uid','=',user.id)]</field>
        <field name="groups" eval="[(4, ref('assetflow_erp.group_employee'))]"/>
    </record>

    <record id="asset_rule_department_scope" model="ir.rule">
        <field name="name">Asset Department Head Scope</field>
        <field name="model_id" ref="model_asset_asset"/>
        <field name="domain_force">[('department_id','=',user.employee_id.department_id.id)]</field>
        <field name="groups" eval="[(4, ref('assetflow_erp.group_department_head'))]"/>
    </record>

    <record id="notification_rule_own" model="ir.rule">
        <field name="name">Notification Own Scope</field>
        <field name="model_id" ref="model_asset_notification"/>
        <field name="domain_force">[('recipient_id','=',user.id)]</field>
        <field name="groups" eval="[(4, ref('assetflow_erp.group_employee'))]"/>
    </record>

    <record id="asset_rule_manager_all" model="ir.rule">
        <field name="name">Asset Manager All Scope</field>
        <field name="model_id" ref="model_asset_asset"/>
        <field name="domain_force">[(1, '=', 1)]</field>
        <field name="groups" eval="[(4, ref('assetflow_erp.group_asset_manager')), (4, ref('assetflow_erp.group_admin'))]"/>
    </record>
</odoo>
