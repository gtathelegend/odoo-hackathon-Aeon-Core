<odoo>
    <record id="view_audit_cycle_tree" model="ir.ui.view">
        <field name="name">audit.cycle.tree</field>
        <field name="model">audit.cycle</field>
        <field name="arch" type="xml">
            <tree>
                <field name="name"/>
                <field name="scope_type"/>
                <field name="start_date"/>
                <field name="end_date"/>
                <field name="status"/>
            </tree>
        </field>
    </record>

    <record id="action_audit_cycle" model="ir.actions.act_window">
        <field name="name">Audit Cycles</field>
        <field name="res_model">audit.cycle</field>
        <field name="view_mode">tree,form</field>
    </record>
</odoo>
