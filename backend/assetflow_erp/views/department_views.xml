<odoo>
    <record id="view_hr_department_tree_assetflow" model="ir.ui.view">
        <field name="name">hr.department.assetflow.tree</field>
        <field name="model">hr.department</field>
        <field name="arch" type="xml">
            <tree>
                <field name="name"/>
                <field name="assetflow_head_user_id"/>
                <field name="parent_id"/>
                <field name="active"/>
            </tree>
        </field>
    </record>

    <record id="action_hr_department_assetflow" model="ir.actions.act_window">
        <field name="name">Departments</field>
        <field name="res_model">hr.department</field>
        <field name="view_mode">tree,form</field>
    </record>

    <menuitem id="menu_assetflow_departments" parent="menu_assetflow_org_setup" action="action_hr_department_assetflow" sequence="10"/>
</odoo>
