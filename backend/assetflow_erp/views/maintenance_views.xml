<odoo>
    <record id="view_maintenance_request_kanban" model="ir.ui.view">
        <field name="name">maintenance.request.kanban</field>
        <field name="model">maintenance.request</field>
        <field name="arch" type="xml">
            <kanban default_group_by="status">
                <field name="asset_id"/>
                <field name="issue_description"/>
                <templates>
                    <t t-name="kanban-box">
                        <div>
                            <strong><field name="asset_id"/></strong>
                            <div><field name="issue_description"/></div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <record id="action_maintenance_request" model="ir.actions.act_window">
        <field name="name">Maintenance</field>
        <field name="res_model">maintenance.request</field>
        <field name="view_mode">kanban,tree,form</field>
    </record>
</odoo>
