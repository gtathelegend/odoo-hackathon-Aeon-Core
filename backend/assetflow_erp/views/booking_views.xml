<odoo>
    <record id="view_asset_booking_tree" model="ir.ui.view">
        <field name="name">asset.booking.tree</field>
        <field name="model">asset.booking</field>
        <field name="arch" type="xml">
            <tree>
                <field name="asset_id"/>
                <field name="booker_id"/>
                <field name="start_time"/>
                <field name="end_time"/>
                <field name="status"/>
            </tree>
        </field>
    </record>

    <record id="action_asset_booking" model="ir.actions.act_window">
        <field name="name">Bookings</field>
        <field name="res_model">asset.booking</field>
        <field name="view_mode">tree,form</field>
    </record>
</odoo>
