<odoo>
    <record id="ir_cron_overdue_allocations" model="ir.cron">
        <field name="name">AssetFlow Overdue Allocations</field>
        <field name="model_id" ref="model_asset_allocation"/>
        <field name="state">code</field>
        <field name="code">model.cron_check_overdue_allocations()</field>
        <field name="interval_number">1</field>
        <field name="interval_type">days</field>
    </record>

    <record id="ir_cron_transition_bookings" model="ir.cron">
        <field name="name">AssetFlow Booking Transitions</field>
        <field name="model_id" ref="model_asset_booking"/>
        <field name="state">code</field>
        <field name="code">model.cron_transition_bookings()</field>
        <field name="interval_number">5</field>
        <field name="interval_type">minutes</field>
    </record>

    <record id="ir_cron_booking_reminders" model="ir.cron">
        <field name="name">AssetFlow Booking Reminders</field>
        <field name="model_id" ref="model_asset_booking"/>
        <field name="state">code</field>
        <field name="code">model.cron_send_booking_reminders()</field>
        <field name="interval_number">15</field>
        <field name="interval_type">minutes</field>
    </record>

    <record id="ir_cron_notification_retry" model="ir.cron">
        <field name="name">AssetFlow Notification Retry</field>
        <field name="model_id" ref="model_asset_notification"/>
        <field name="state">code</field>
        <field name="code">model.cron_retry_failed_notifications()</field>
        <field name="interval_number">1</field>
        <field name="interval_type">minutes</field>
    </record>

    <record id="ir_cron_user_timeout" model="ir.cron">
        <field name="name">AssetFlow Idle Session Cleanup</field>
        <field name="model_id" ref="base.model_res_users"/>
        <field name="state">code</field>
        <field name="code">model.cron_expire_idle_users()</field>
        <field name="interval_number">10</field>
        <field name="interval_type">minutes</field>
    </record>
</odoo>
